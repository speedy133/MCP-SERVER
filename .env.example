# ──────────────────────────────────────────────
# Weekly Pulse Pipeline — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Do NOT commit the .env file to version control.
# ──────────────────────────────────────────────

# LLM API Key (e.g., Google Gemini)
LLM_API_KEY=your_llm_api_key_here

# Groq API Key (for final report/email drafting)
GROQ_API_KEY=your_groq_api_key_here

# MCP Server URLs
MCP_DOCS_SERVER_URL=http://localhost:3000/docs
MCP_GMAIL_SERVER_URL=http://localhost:3000/gmail

# App Store IDs
APP_ID_PLAY_STORE=com.example.app
APP_ID_APP_STORE=123456789

# Notification recipient
RECIPIENT_EMAIL=your_email@example.com
