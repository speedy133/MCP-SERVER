# ──────────────────────────────────────────────
# Weekly Pulse Pipeline — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Do NOT commit the .env file to version control.
# ──────────────────────────────────────────────

# LLM API Key (e.g., Google Gemini)
LLM_API_KEY=your_llm_api_key_here

# Groq API Key (for final report/email drafting)
GROQ_API_KEY=your_groq_api_key_here

# MCP Server URLs
MCP_DOCS_SERVER_URL=https://your-mcp-server.up.railway.app/sse
MCP_GMAIL_SERVER_URL=https://your-mcp-server.up.railway.app/sse

# Notification recipient
RECIPIENT_EMAIL=your_email@example.com

# ──────────────────────────────────────────────
# Optional: Default App IDs for Automated Runs
# ──────────────────────────────────────────────
# These are used by Railway's cron job when the script is run without arguments.
DEFAULT_PLAY_STORE_ID=com.example.app
DEFAULT_APP_STORE_ID=123456789

